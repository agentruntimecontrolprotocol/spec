' Shared dark-theme skinparams for ARCP sequence diagrams.
scale 1.1
skinparam backgroundColor transparent
skinparam defaultFontName TT Commons Pro
skinparam shadowing false
skinparam roundcorner 4

skinparam sequence {
  ParticipantBorderColor      #475569
  ParticipantBackgroundColor  #1E293B
  ParticipantFontColor        #F1F5F9
  ParticipantFontName         TT Commons Pro
  ParticipantFontSize         13
  ParticipantFontStyle        plain
  ParticipantPadding          16

  ArrowColor                  #64748B
  ArrowFontColor              #CBD5E1
  ArrowFontName               Operator Mono
  ArrowFontSize               12
  ArrowFontStyle              plain
  ArrowThickness              1.1

  LifeLineBorderColor         #334155
  LifeLineBackgroundColor     transparent

  GroupBorderColor            #475569
  GroupBackgroundColor        #1E293B
  GroupHeaderFontColor        #F1F5F9
  GroupHeaderFontSize         12
  GroupHeaderFontStyle        plain
  GroupBodyBackgroundColor    transparent
  GroupFontName               TT Commons Pro

  DividerBorderColor          #334155
  DividerBackgroundColor      #1E293B
  DividerFontColor            #CBD5E1
  DividerFontSize             12
  DividerFontStyle            plain

  NoteBorderColor             #475569
  NoteBackgroundColor         #1E293B
  NoteFontColor               #F1F5F9
  NoteFontSize                12
  NoteFontName                TT Commons Pro
}

' Palette tokens (dark)
!$client_color   = "#60A5FA"
!$client_arrow   = "#60A5FA"
!$reply_arrow    = "#64748B"
!$muted_arrow    = "#475569"
!$accent_arrow   = "#FBBF24"
!$accent_text    = "#FBBF24"
!$error_arrow    = "#F87171"
!$error_text     = "#F87171"
!$success_arrow  = "#34D399"
!$success_text   = "#34D399"
!$peer_color     = "#34D399"
!$gateway_color  = "#A78BFA"
